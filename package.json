{
  "name": "puck-plugin-accessibility-checker",
  "version": "0.0.1",
  "description": "A plugin for the Puck editor that tests for accessibility issues using axe-core",
  "license": "GPL-3.0",
  "author": "Tobias Lahmann (tobiaslahmann@gmail.com)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tlahmann/puck-plugin-accessibility-checker.git"
  },
  "keywords": [
    "puck",
    "puck-editor",
    "plugin",
    "accesibility",
    "axe-core"
  ],
  "bugs": {
    "url": "https://github.com/tlahmann/puck-plugin-accessibility-checker/issues"
  },
  "homepage": "https://github.com/tlahmann/puck-plugin-accessibility-checker#readme",
  "devDependencies": {
    "@puckeditor/core": "^0.21.1",
    "@types/node": "^22.15.5",
    "@types/react": "^18.3.27",
    "lucide-react": "^0.577.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "tsup": "^8.4.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@puckeditor/core": "^0.21.1",
    "lucide-react": "^0.577.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  }
}
